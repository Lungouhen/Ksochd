generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String   @id @default(cuid())
  name              String
  phone             String   @unique
  email             String?  @unique
  password          String?  // Optional for phone-only auth
  clan              String?
  college           String?
  role              Role     @default(MEMBER)
  membershipStatus  Status   @default(PENDING)
  profilePic        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  registrations     EventRegistration[]
  notifications     Notification[]
  payments          Payment[]
}

model Event {
  id                   String   @id @default(cuid())
  title                String
  description          String
  date                 DateTime
  venue                String
  fee                  Int      @default(0)
  registrationDeadline DateTime
  posterUrl            String?
  createdBy            String   // admin userId
  createdAt            DateTime @default(now())

  registrations EventRegistration[]
}

model EventRegistration {
  id         String   @id @default(cuid())
  userId     String
  eventId    String
  status     RegistrationStatus @default(PENDING)
  paymentId  String?
  createdAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])
}

model Content {
  id         String   @id @default(cuid())
  type       ContentType
  title      String
  body       String?
  visibility Visibility @default(PUBLIC)
  mediaUrl   String?
  createdAt  DateTime @default(now())
}

model Payment {
  id         String   @id @default(cuid())
  userId     String
  amount     Int
  status     PaymentStatus
  razorpayId String?
  purpose    String   // "membership" or "event"
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // e.g., "ROLE_CHANGED", "MEMBER_APPROVED", "MEMBER_REJECTED"
  targetUserId String?  // The user affected by the action
  targetUserName String? // Snapshot of name at time of action
  performedBy String   // The admin who performed the action
  performedByName String? // Snapshot of admin name
  details     Json?    // Additional context (e.g., old role, new role)
  createdAt   DateTime @default(now())

  @@index([targetUserId])
  @@index([performedBy])
  @@index([createdAt])
}

enum Role {
  MEMBER
  MODERATOR
  ADMIN
}

enum Status {
  PENDING
  ACTIVE
  EXPIRED
  REJECTED
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum ContentType {
  NEWS
  GALLERY
  DOCUMENT
  ANNOUNCEMENT
}

enum Visibility {
  PUBLIC
  MEMBER
  ADMIN
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String?
  isSecret    Boolean  @default(false)
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

model ExecutiveTerm {
  id          String   @id @default(cuid())
  name        String   // e.g., "2025-2026"
  startYear   Int      // e.g., 2025
  endYear     Int      // e.g., 2026
  startDate   DateTime // Term start date
  endDate     DateTime // Term end date
  isCurrent   Boolean  @default(false) // Only one term can be current
  description String?  // Optional description
  createdBy   String   // Admin who created the term
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isCurrent])
  @@index([startYear])
  @@index([endYear])
}

// CMS Models
model Page {
  id          String      @id @default(cuid())
  slug        String      @unique
  title       String
  content     String      @db.Text
  excerpt     String?
  customCss   String?     @db.Text
  customJs    String?     @db.Text
  status      PageStatus  @default(DRAFT)
  themeId     String?
  seoId       String?     @unique
  publishedAt DateTime?
  createdBy   String
  updatedBy   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  theme       Theme?      @relation(fields: [themeId], references: [id])
  seo         SEO?        @relation(fields: [seoId], references: [id])
  blocks      PageBlock[]
  versions    PageVersion[]

  @@index([slug])
  @@index([status])
}

model PageBlock {
  id              String    @id @default(cuid())
  pageId          String?
  type            BlockType
  content         String    @db.Text
  settings        Json?
  order           Int       @default(0)
  isReusable      Boolean   @default(false)
  reusableName    String?
  isGlobal        Boolean   @default(false)
  sourceBlockId   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  page            Page?     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([isReusable])
  @@index([isGlobal])
}

model MediaLibrary {
  id          String    @id @default(cuid())
  filename    String
  url         String
  type        MediaType
  size        Int       // in bytes
  alt         String?
  caption     String?
  uploadedBy  String
  createdAt   DateTime  @default(now())

  @@index([type])
  @@index([uploadedBy])
}

// SEO Models
model SEO {
  id               String   @id @default(cuid())
  title            String
  description      String
  keywords         String?
  ogTitle          String?
  ogDescription    String?
  ogImage          String?
  twitterCard      String?  @default("summary_large_image")
  twitterTitle     String?
  twitterDescription String?
  twitterImage     String?
  canonicalUrl     String?
  noindex          Boolean  @default(false)
  nofollow         Boolean  @default(false)
  structuredData   Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  page             Page?
}

// Theme Models
model Theme {
  id          String      @id @default(cuid())
  name        String      @unique
  displayName String
  description String?
  isActive    Boolean     @default(false)
  isDefault   Boolean     @default(false)
  config      Json        // JSON for theme configuration
  preview     String?     // Preview image URL
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  pages       Page[]

  @@index([isActive])
}

// Ads Models
model Ad {
  id          String     @id @default(cuid())
  name        String
  type        AdType
  position    AdPosition
  content     String     @db.Text // HTML/Script content
  imageUrl    String?
  linkUrl     String?
  isActive    Boolean    @default(true)
  startDate   DateTime?
  endDate     DateTime?
  impressions Int        @default(0)
  clicks      Int        @default(0)
  createdBy   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([position])
  @@index([isActive])
  @@index([type])
}

// GTM Configuration
model GTMConfig {
  id            String   @id @default(cuid())
  containerId   String   // GTM container ID (e.g., GTM-XXXXXX)
  isEnabled     Boolean  @default(true)
  environment   String?  // For GTM environment variables
  customEvents  Json?    // Custom event configurations
  updatedAt     DateTime @updatedAt
  updatedBy     String?
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BlockType {
  HEADING
  PARAGRAPH
  IMAGE
  VIDEO
  GALLERY
  QUOTE
  CODE
  DIVIDER
  BUTTON
  FORM
  CUSTOM_HTML
  HERO
  FEATURE_GRID
  TESTIMONIAL
  PRICING_TABLE
  FAQ_ACCORDION
  CTA_BANNER
  STATS_COUNTER
  TEAM_GRID
  TIMELINE
  MAP_EMBED
  SOCIAL_FEED
  NEWSLETTER_FORM
  TABS
  ACCORDION
  CAROUSEL
  TABLE
  ALERT
  SPACER
  ICON_LIST
  LOGO_GRID
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
}

enum AdType {
  BANNER
  SIDEBAR
  INLINE
  POPUP
  NATIVE
}

enum AdPosition {
  HEADER
  FOOTER
  SIDEBAR_LEFT
  SIDEBAR_RIGHT
  CONTENT_TOP
  CONTENT_MIDDLE
  CONTENT_BOTTOM
  POPUP
}

// ─── Branding & Organization Config ─────────────────────────────────────

model BrandingConfig {
  id              String   @id @default(cuid())
  key             String   @unique  // e.g., "logo_url", "primary_color", "font_family"
  value           String?  @db.Text
  category        String   @default("general") // "logo", "colors", "typography", "layout"
  description     String?
  updatedAt       DateTime @updatedAt
  updatedBy       String?

  @@index([category])
}

// ─── Configurable ID Formats ────────────────────────────────────────────

model IdFormatConfig {
  id              String   @id @default(cuid())
  entityType      String   @unique // "member", "receipt", "invoice", "event", "payment"
  prefix          String   @default("") // e.g., "KSO-", "REC-", "INV-"
  separator       String   @default("-") // separator between prefix and number
  padLength       Int      @default(6) // zero-pad length
  nextSequence    Int      @default(1) // auto-increment counter
  format          String   @default("{{prefix}}{{separator}}{{sequence}}") // format template
  suffix          String?  // optional suffix
  includeYear     Boolean  @default(false) // include year in ID
  includeMonth    Boolean  @default(false) // include month in ID
  description     String?
  updatedAt       DateTime @updatedAt
  updatedBy       String?

  @@index([entityType])
}

// ─── Output Templates ───────────────────────────────────────────────────

model OutputTemplate {
  id              String   @id @default(cuid())
  name            String
  type            String   // "id_card", "receipt", "invoice", "report", "certificate"
  layout          String   @db.Text // HTML/CSS template with {{placeholders}}
  placeholders    Json?    // list of available placeholders and descriptions
  isDefault       Boolean  @default(false)
  isActive        Boolean  @default(true)
  description     String?
  previewImage    String?
  createdBy       String
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@index([type])
  @@index([isActive])
}

// ─── Custom Fields ──────────────────────────────────────────────────────

model CustomField {
  id              String   @id @default(cuid())
  module          String   // "members", "events", "payments", "content"
  fieldName       String   // machine-readable key
  label           String   // human-readable label
  fieldType       FieldType
  placeholder     String?
  defaultValue    String?
  options         Json?    // for select/radio/checkbox: array of options
  validationRules Json?    // min, max, regex, required, etc.
  order           Int      @default(0)
  isRequired      Boolean  @default(false)
  isActive        Boolean  @default(true)
  description     String?
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  values          CustomFieldValue[]

  @@unique([module, fieldName])
  @@index([module])
  @@index([isActive])
}

model CustomFieldValue {
  id              String   @id @default(cuid())
  fieldId         String
  entityId        String   // ID of the member/event/payment this value belongs to
  value           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  field           CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([fieldId, entityId])
  @@index([entityId])
}

enum FieldType {
  TEXT
  TEXTAREA
  NUMBER
  EMAIL
  PHONE
  DATE
  DATETIME
  SELECT
  MULTI_SELECT
  RADIO
  CHECKBOX
  FILE
  URL
  COLOR
  RICH_TEXT
}

// ─── Module Toggles ─────────────────────────────────────────────────────

model ModuleToggle {
  id              String   @id @default(cuid())
  moduleKey       String   @unique // "events", "payments", "gallery", "cms", "ads", "reports", etc.
  displayName     String
  description     String?
  isEnabled       Boolean  @default(true)
  permissions     Json?    // role-based permissions for this module
  config          Json?    // module-specific configuration
  order           Int      @default(0)
  updatedAt       DateTime @updatedAt
  updatedBy       String?

  @@index([isEnabled])
}

// ─── Saved Report Views ─────────────────────────────────────────────────

model SavedReportView {
  id              String   @id @default(cuid())
  name            String
  reportType      String   // "members", "financial", "events", "engagement"
  filters         Json     // saved filter configuration
  columns         Json?    // visible columns and order
  sortConfig      Json?    // sort column and direction
  exportFormat    String?  // "csv", "pdf", "xlsx"
  isDefault       Boolean  @default(false)
  isShared        Boolean  @default(false)
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([reportType])
  @@index([createdBy])
}

// ─── Page Versioning ────────────────────────────────────────────────────

model PageVersion {
  id              String   @id @default(cuid())
  pageId          String
  versionNumber   Int
  title           String
  content         String   @db.Text
  customCss       String?  @db.Text
  customJs        String?  @db.Text
  blocks          Json?    // snapshot of blocks at this version
  status          PageStatus
  changeNote      String?
  createdBy       String
  createdAt       DateTime @default(now())

  page            Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, versionNumber])
  @@index([pageId])
}

// ─── Settings Versioning ────────────────────────────────────────────────

model SettingsBackup {
  id              String   @id @default(cuid())
  name            String
  category        String   // "branding", "id_formats", "templates", "modules", "all"
  data            Json     // snapshot of settings
  description     String?
  createdBy       String
  createdAt       DateTime @default(now())

  @@index([category])
}

// ─── Hook/Extension System ──────────────────────────────────────────────

model HookRegistration {
  id              String   @id @default(cuid())
  hookPoint       String   // "before_member_create", "after_payment_success", etc.
  name            String
  description     String?
  handlerType     String   // "webhook", "internal", "script"
  handlerConfig   Json     // URL for webhook, function path for internal, script content
  priority        Int      @default(10)
  isActive        Boolean  @default(true)
  conditions      Json?    // optional conditions for when to trigger
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([hookPoint])
  @@index([isActive])
}
