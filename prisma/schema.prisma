generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  name              String
  phone             String   @unique
  email             String?  @unique
  clan              String?
  college           String?
  role              Role     @default(MEMBER)
  membershipStatus  Status   @default(PENDING)
  profilePic        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  registrations     EventRegistration[]
  notifications     Notification[]
  payments          Payment[]
}

model Event {
  id                   String   @id @default(cuid())
  title                String
  description          String
  date                 DateTime
  venue                String
  fee                  Int      @default(0)
  registrationDeadline DateTime
  posterUrl            String?
  createdBy            String   // admin userId
  createdAt            DateTime @default(now())

  registrations EventRegistration[]
}

model EventRegistration {
  id         String   @id @default(cuid())
  userId     String
  eventId    String
  status     RegistrationStatus @default(PENDING)
  paymentId  String?
  createdAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])
}

model Content {
  id         String   @id @default(cuid())
  type       ContentType
  title      String
  body       String?
  visibility Visibility @default(PUBLIC)
  mediaUrl   String?
  createdAt  DateTime @default(now())
}

model Payment {
  id         String   @id @default(cuid())
  userId     String
  amount     Int
  status     PaymentStatus
  razorpayId String?
  purpose    String   // "membership" or "event"
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum Role {
  MEMBER
  MODERATOR
  ADMIN
}

enum Status {
  PENDING
  ACTIVE
  EXPIRED
  REJECTED
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum ContentType {
  NEWS
  GALLERY
  DOCUMENT
  ANNOUNCEMENT
}

enum Visibility {
  PUBLIC
  MEMBER
  ADMIN
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String?
  isSecret    Boolean  @default(false)
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

// CMS Models
model Page {
  id          String      @id @default(cuid())
  slug        String      @unique
  title       String
  content     String      @db.Text
  excerpt     String?
  status      PageStatus  @default(DRAFT)
  themeId     String?
  seoId       String?     @unique
  publishedAt DateTime?
  createdBy   String
  updatedBy   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  theme       Theme?      @relation(fields: [themeId], references: [id])
  seo         SEO?        @relation(fields: [seoId], references: [id])
  blocks      PageBlock[]

  @@index([slug])
  @@index([status])
}

model PageBlock {
  id        String    @id @default(cuid())
  pageId    String
  type      BlockType
  content   String    @db.Text
  settings  String?   @db.Json // JSON for block-specific settings
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  page      Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
}

model MediaLibrary {
  id          String    @id @default(cuid())
  filename    String
  url         String
  type        MediaType
  size        Int       // in bytes
  alt         String?
  caption     String?
  uploadedBy  String
  createdAt   DateTime  @default(now())

  @@index([type])
  @@index([uploadedBy])
}

// SEO Models
model SEO {
  id               String   @id @default(cuid())
  title            String
  description      String
  keywords         String?
  ogTitle          String?
  ogDescription    String?
  ogImage          String?
  twitterCard      String?  @default("summary_large_image")
  twitterTitle     String?
  twitterDescription String?
  twitterImage     String?
  canonicalUrl     String?
  noindex          Boolean  @default(false)
  nofollow         Boolean  @default(false)
  structuredData   String?  @db.Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  page             Page?
}

// Theme Models
model Theme {
  id          String      @id @default(cuid())
  name        String      @unique
  displayName String
  description String?
  isActive    Boolean     @default(false)
  isDefault   Boolean     @default(false)
  config      String      @db.Json // JSON for theme configuration
  preview     String?     // Preview image URL
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  pages       Page[]

  @@index([isActive])
}

// Ads Models
model Ad {
  id          String     @id @default(cuid())
  name        String
  type        AdType
  position    AdPosition
  content     String     @db.Text // HTML/Script content
  imageUrl    String?
  linkUrl     String?
  isActive    Boolean    @default(true)
  startDate   DateTime?
  endDate     DateTime?
  impressions Int        @default(0)
  clicks      Int        @default(0)
  createdBy   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([position])
  @@index([isActive])
  @@index([type])
}

// GTM Configuration
model GTMConfig {
  id            String   @id @default(cuid())
  containerId   String   // GTM container ID (e.g., GTM-XXXXXX)
  isEnabled     Boolean  @default(true)
  environment   String?  // For GTM environment variables
  customEvents  String?  @db.Json // Custom event configurations
  updatedAt     DateTime @updatedAt
  updatedBy     String?
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BlockType {
  HEADING
  PARAGRAPH
  IMAGE
  VIDEO
  GALLERY
  QUOTE
  CODE
  DIVIDER
  BUTTON
  FORM
  CUSTOM_HTML
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
}

enum AdType {
  BANNER
  SIDEBAR
  INLINE
  POPUP
  NATIVE
}

enum AdPosition {
  HEADER
  FOOTER
  SIDEBAR_LEFT
  SIDEBAR_RIGHT
  CONTENT_TOP
  CONTENT_MIDDLE
  CONTENT_BOTTOM
  POPUP
}
