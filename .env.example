# Replace with your Supabase or PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ksochd"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_JWT_SECRET="your-jwt-secret"

# Razorpay Configuration
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"

# Google Tag Manager (optional)
NEXT_PUBLIC_GTM_CONTAINER_ID="GTM-XXXXXX"

# Security
JWT_SECRET="your-jwt-secret-for-csrf-tokens"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
