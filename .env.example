# Replace with your Supabase or PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ksochd"

# Payment Gateways
# Razorpay
RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"

# Stripe
STRIPE_PUBLIC_KEY="your_stripe_publishable_key"
STRIPE_SECRET_KEY="your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret"

# PayPal
PAYPAL_CLIENT_ID="your_paypal_client_id"
PAYPAL_CLIENT_SECRET="your_paypal_client_secret"
PAYPAL_MODE="sandbox" # or "live" for production

# Active payment gateway (RAZORPAY, STRIPE, or PAYPAL)
ACTIVE_PAYMENT_GATEWAY="RAZORPAY"
