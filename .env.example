# Database Connection
# For local: postgresql://postgres:postgres@localhost:5432/ksochd
# For Supabase: Get from Settings > Database > Connection String (use Transaction pooler for production)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ksochd"

# JWT Secret (REQUIRED - Change in production!)
# Must be at least 32 characters for security
JWT_SECRET="your-secret-key-change-in-production-min-32-chars-please-use-strong-random-string"

# Supabase Configuration
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Google Tag Manager (optional)
NEXT_PUBLIC_GTM_CONTAINER_ID="GTM-XXXXXX"

# AI Gateway API Key (optional)
AI_GATEWAY_API_KEY="your-ai-gateway-api-key-here"

# Resend API Key (for email notifications)
RESEND_API_KEY="your-resend-api-key-here"
